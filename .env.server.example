PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
ALLOW_ORIGIN=*

ELEVENLABS_API_KEY=replace_with_your_rotated_elevenlabs_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# News feed providers used by the backend /api/feed route.
GUARDIAN_KEY=replace_with_your_guardian_key
GNEWS_KEY=replace_with_your_gnews_key

# OpenAI — used for vocab translation (/api/vocab/translate) and AI conversation (/api/chat).
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
