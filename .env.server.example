PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
ALLOW_ORIGIN=*

ELEVENLABS_API_KEY=replace_with_your_rotated_elevenlabs_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# News feed providers used by the backend /api/feed route.
GUARDIAN_KEY=replace_with_your_guardian_key
GNEWS_KEY=replace_with_your_gnews_key

# OpenAI — used for vocab translation (/api/vocab/translate) and AI conversation (/api/chat).
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Supabase — used by trusted backend routes such as mock subscription upgrades.
# SUPABASE_URL and SUPABASE_ANON_KEY can match the public Expo Supabase values.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_your_supabase_anon_or_publishable_key

# Server-only elevated Supabase key. Store this only in Render/server env vars.
# Never add this to Expo/EAS env vars, app config, or any client-side file.
# Supabase may show this as a legacy service_role key or newer secret API key.
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_server_only_secret_key
