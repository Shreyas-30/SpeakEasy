# Copy this file to .env and fill in your API keys

# Optional local-only fallback for direct feed fetching during development.
# In production/TestFlight, feed requests should go through the backend instead.
EXPO_PUBLIC_GUARDIAN_KEY=your_guardian_key_here

# Optional local-only fallback for direct feed fetching during development.
EXPO_PUBLIC_GNEWS_KEY=your_gnews_key_here

# Text-to-speech mode
# Use "device" for local Expo speech during development.
# Use "elevenlabs-proxy" once you have a backend endpoint that calls ElevenLabs securely.
EXPO_PUBLIC_TTS_MODE=elevenlabs-proxy

# Public backend endpoint for TTS and translation requests.
# Do not put the ElevenLabs or OpenAI secret in the app.
EXPO_PUBLIC_TTS_PROXY_URL=https://your-render-backend.onrender.com/api/tts

# Public default voice identifier. Keep this aligned with ELEVENLABS_VOICE_ID on the proxy if
# you want first-playback voice and the preselected Settings voice to match.
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=your_default_voice_id_here
