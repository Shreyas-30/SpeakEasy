# Copy this file to .env and fill in your API keys

# Optional local-only fallback for direct feed fetching during development.
# In production/TestFlight, feed requests should go through the backend instead.
EXPO_PUBLIC_GUARDIAN_KEY=your_guardian_key_here

# Optional local-only fallback for direct feed fetching during development.
EXPO_PUBLIC_GNEWS_KEY=your_gnews_key_here

# Public backend endpoint for feed, TTS, Realtime session, translation, and subscription requests.
# Do not put OpenAI, news provider, or Supabase service-role secrets in the app.
EXPO_PUBLIC_BACKEND_URL=https://your-render-backend.onrender.com

# Backward-compatible fallback while old EAS env names are being replaced.
EXPO_PUBLIC_TTS_PROXY_URL=https://your-render-backend.onrender.com

# Supabase client config
# These are public client values. Never put a Supabase service role key in the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY
